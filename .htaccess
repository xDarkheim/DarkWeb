# DarkCore — Root .htaccess
# This file protects the project root when Apache DocumentRoot is NOT set to public/.
# In a correctly configured environment (Docker / production), DocumentRoot points
# to the public/ directory and this file is never served.

# Block direct access to sensitive directories and files outside public/.
<IfModule mod_rewrite.c>
    RewriteEngine On

    # If DocumentRoot is the project root (dev misconfiguration), redirect to public/.
    RewriteCond %{REQUEST_URI} !^/public/
    RewriteRule ^(.*)$ /public/$1 [L,R=301]
</IfModule>

# Deny access to everything by default as a safety net.
<IfModule mod_authz_core.c>
    Require all denied
</IfModule>

