{
    "name": "darkheim/muonline-cms",
    "description": "DarkWeb MuOnline CMS",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "ext-curl": "*",
        "ext-gd": "*",
        "ext-json": "*",
        "ext-mbstring": "*",
        "ext-pdo": "*",
        "ext-pdo_dblib": "*",
        "ext-simplexml": "*",
        "ext-xml": "*",
        "ext-zip": "*",
        "google/recaptcha": "^1.3",
        "phpmailer/phpmailer": "^6.9",
      "ext-dom": "*",
      "ext-libxml": "*"
    },
    "autoload": {
        "psr-4": {
            "Darkheim\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "preferred-install": "dist",
        "allow-plugins": {},
        "platform": {
            "php": "8.4.0",
            "ext-curl": "8.4.0",
            "ext-gd": "8.4.0",
            "ext-json": "8.4.0",
            "ext-mbstring": "8.4.0",
            "ext-pdo": "8.4.0",
            "ext-pdo_dblib": "8.4.0",
            "ext-simplexml": "8.4.0",
            "ext-xml": "8.4.0",
            "ext-zip": "8.4.0"
        }
    },
    "prefer-stable": true,
    "scripts": {
        "post-install-cmd": [
            "@composer dump-autoload --optimize"
        ],
        "post-update-cmd": [
            "@composer dump-autoload --optimize"
        ],
        "test": "phpunit --no-coverage",
        "analyse": "phpstan analyse --memory-limit=256M",
        "fix": "php-cs-fixer fix --diff",
        "check": "php-cs-fixer fix --dry-run --diff"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.94",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^11"
    }
}
