parameters:
    phpVersion: 80400
    level: 5

    paths:
        - src/

    # Global helper functions and constants are loaded at runtime from
    # includes/bootstrap/compat.php and config/tables.php — tell PHPStan
    # about them so they don't produce "function/constant not found" errors.
    bootstrapFiles:
        - includes/bootstrap/compat.php
        - config/tables.php
        - config/tables.custom.php

    # Ignore errors caused by runtime-defined constants (DB column/table names
    # from tables.php) and other project-specific patterns.
    ignoreErrors:
        # Runtime-defined DB column/table constants (tables.php) may be undefined
        # in environments without a live DB – suppress at PHPStan level.
        - '#Constant [A-Za-z0-9_]+ not found\.#'

    excludePaths:
        - vendor/
        - public/install/
        - docker/
