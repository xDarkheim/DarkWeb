# Docker runtime configuration
# Copy this file to docker/config.env and adjust for your environment.
# docker/config.env is git-ignored and never committed.
#
# ── Local development defaults ────────────────────────────────────────────────

# Domain / hostname used as Apache ServerName and Xdebug serverName.
# Local: use localhost. Production: use your actual domain.
DOCKER_SERVER_NAME=localhost

# IANA timezone applied inside the container.
# See: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
DOCKER_TIMEZONE=UTC

# Full URL of the cron endpoint (called every minute by the internal cron job).
# Local: use http. Include ?key= matching cron_api_key in config.json.
# Leave empty to disable the cron job.
DOCKER_CRON_URL=http://localhost:8081/api/cron.php?key=123456

# Xdebug 3 mode. Values: off | debug | profile | trace | coverage
# Comma-separated combos are supported: debug,coverage
# Use "off" in production.
DOCKER_XDEBUG_MODE=off

